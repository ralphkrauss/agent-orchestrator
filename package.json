{
  "name": "@ralphkrauss/agent-orchestrator",
  "version": "0.2.2",
  "description": "Local MCP orchestrator for supervising Codex, Claude, Cursor, and OpenCode worker runs.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "agent-orchestrator": "dist/cli.js",
    "agent-orchestrator-daemon": "dist/daemonCli.js",
    "agent-orchestrator-opencode": "dist/opencodeCli.js",
    "agent-orchestrator-claude": "dist/claudeCli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/__tests__/*.test.js dist/__tests__/integration/*.test.js",
    "audit:prod": "pnpm audit --prod",
    "verify": "pnpm build && pnpm test && node scripts/check-publish-ready.mjs && node scripts/resolve-publish-tag.mjs >/dev/null && pnpm audit --prod && npm pack --dry-run",
    "prepack": "pnpm build",
    "pack:dry-run": "npm pack --dry-run"
  },
  "files": [
    "dist/",
    "src/",
    "!dist/__tests__/",
    "!src/__tests__/",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "SUPPORT.md",
    "ROADMAP.md",
    "CODE_OF_CONDUCT.md",
    "docs/",
    "PUBLISHING.md",
    "LICENSE.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ralphkrauss/agent-orchestrator.git"
  },
  "bugs": {
    "url": "https://github.com/ralphkrauss/agent-orchestrator/issues"
  },
  "homepage": "https://github.com/ralphkrauss/agent-orchestrator#readme",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent-orchestration",
    "codex-cli",
    "claude-code",
    "cursor",
    "opencode",
    "typescript",
    "nodejs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ink": "^7.0.2",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.6",
    "ulid": "^2.4.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@cursor/sdk": "^1.0.12"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.15.18",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "path-to-regexp": ">=8.4.0"
  },
  "pnpm": {
    "overrides": {
      "tar": "^7.5.11",
      "undici": "^6.24.0",
      "@tootallnate/once": "^3.0.1",
      "ip-address": "^10.1.1"
    },
    "onlyBuiltDependencies": [
      "sqlite3"
    ]
  },
  "packageManager": "pnpm@10.30.3"
}
